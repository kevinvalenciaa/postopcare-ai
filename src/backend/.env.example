# Copy to .env and fill in real values. Never commit .env.

# OpenAI (POC-002, POC-005, POC-007, POC-013, POC-014)
OPENAI_API_KEY=sk-...

# NCBI / PubMed (POC-001) — optional but raises rate limit from 3 to 10 req/sec
NCBI_API_KEY=

# Pinecone (POC-005)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=postopcare-rag

# Database (POC-011) — defaults to local SQLite
DATABASE_URL=sqlite:///./postopcare.db

# Patient share URLs — base used to encode QR codes and build /h/{slug} links
PUBLIC_BASE_URL=http://localhost:3000

# Logging
LOG_LEVEL=INFO
